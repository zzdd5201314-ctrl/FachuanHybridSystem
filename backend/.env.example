# ============================================================
# 法穿案件管理系统 - 环境配置示例
# ============================================================
#
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改 DJANGO_SECRET_KEY（生产环境必须修改）
# 3. 启动系统后在 Admin 后台配置其他选项
#
# 配置管理：
# - 基础配置：本文件（Django 启动必需）
# - 业务配置：Admin 后台 -> 核心系统 -> 系统配置
#

# ============================================================
# Django 核心配置（必需）
# ============================================================

# Django 密钥（生产环境必须修改！）
# 生成命令: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production

# 调试模式（生产环境设为 False）
DJANGO_DEBUG=True

# 允许的主机（生产环境添加你的域名）
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库引擎：默认使用 PostgreSQL（推荐）
# 可选值：postgresql / sqlite
DB_ENGINE=postgresql

# SQLite 模式下生效（留空则使用 backend/apiSystem/db.sqlite3）
DATABASE_PATH=

# PostgreSQL 模式下生效（本地默认值）
DB_NAME=fachuan_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# ============================================================
# 安全凭证配置
# ============================================================

# 冒烟测试管理员密码（生产环境必须设置）
SMOKE_ADMIN_PASSWORD=

# 账号凭证加密密钥（用于加密存储的第三方账号密码）
# 生成命令: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# 爬虫数据加密密钥
SCRAPER_ENCRYPTION_KEY=

# 允许局域网访问（开发/内网联调）
# - 仅用于开发环境；生产环境禁止启用
# - 开启后会放宽 ALLOWED_HOSTS，但仍要求显式设置 CORS/CSRF origins 白名单
# - 仍需以 0.0.0.0 绑定启动：python manage.py runserver 0.0.0.0:8000
DJANGO_ALLOW_LAN=False
DJANGO_LAN_ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# ============================================================
# 缓存配置
# ============================================================
# 系统默认使用 Django 内置的本地内存缓存（LocMemCache）
# 生产建议配置 Redis cache 以支持多进程/多副本一致的限流与缓存
DJANGO_CACHE_REDIS_URL=

# ============================================================
# Channels / WebSocket（可选）
# ============================================================
# 配置后启用 Redis channel layer；不配置则使用 InMemory（仅适合单进程）
DJANGO_CHANNEL_REDIS_URL=

# ============================================================
# CORS（可选）
# ============================================================
# 如果你只使用 Authorization: Bearer（推荐），保持 False
# 如果你需要跨域 Cookie（不推荐），再显式打开，并确保 origins 白名单严格
CORS_ALLOW_CREDENTIALS=False

# ============================================================
# Cookie / Proxy 安全（生产建议）
# ============================================================
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_PROXY_SSL_HEADER=False

# ============================================================
# 外部接口测试脚本（可选）
# ============================================================
COURT_BAOQUAN_TOKEN=your-token-here

# ============================================================
# 上传与请求观测（可选）
# ============================================================

# 请求体内存上限（MB）
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE_MB=20

# 请求耗时统计中间件开关（生产默认开启；显式设置为 false 可关闭）
DJANGO_REQUEST_TIMING=

# ============================================================
# 错误上报（可选）
# ============================================================

# Sentry DSN（留空则不启用）
SENTRY_DSN=

# Sentry APM 采样率（0.0 ~ 1.0，默认 0.1 即 10% 采样）
# 生产环境建议 0.1；开发环境可设为 1.0 全量采样；设为 0 则关闭 APM
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── MCP Server ──────────────────────────────────────────────
# 法穿 API 地址（默认本地）
FACHUAN_BASE_URL=http://127.0.0.1:8002/api/v1
# 用于 MCP Server 调用 API 的账号（建议专用账号）
FACHUAN_USERNAME=
FACHUAN_PASSWORD=
